{
	"schemaVersion": 1,
	"id": "mineip",
	"version": "${version}",
	"name": "mineip",
	"description": "A mod of fun, miscellaneous features!",
	"authors": [
		"minip8"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/mineip/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"io.github.minip8.mineip.Mineip"
		],
		"client": [
			"io.github.minip8.mineip.MineipClient",
			"io.github.minip8.mineip.util.RenderUtil"
		]
	},
	"mixins": [
		"mineip.mixins.json",
		{
			"config": "mineip.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}